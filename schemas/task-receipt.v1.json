{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alp.dev/schemas/task-receipt.v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "task_id",
    "state",
    "accepted_at",
    "status_url"
  ],
  "properties": {
    "protocol_version": {
      "const": "alp.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{16,64}$"
    },
    "state": {
      "type": "string",
      "enum": [
        "accepted",
        "duplicate"
      ]
    },
    "accepted_at": {
      "type": "string",
      "format": "date-time"
    },
    "status_url": {
      "type": "string",
      "format": "uri"
    }
  }
}


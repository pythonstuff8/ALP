{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alp.dev/schemas/result-contract.v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "task_id",
    "issuer",
    "status",
    "confidence",
    "cost",
    "trace",
    "auth"
  ],
  "properties": {
    "protocol_version": {
      "const": "alp.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{16,64}$"
    },
    "issuer": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ]
    },
    "output": {},
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "total_usd",
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "currency": {
          "const": "USD"
        },
        "total_usd": {
          "type": "number",
          "minimum": 0
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_id",
        "received_at",
        "started_at",
        "completed_at",
        "attempts",
        "steps"
      ],
      "properties": {
        "worker_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]{3,128}$"
        },
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "index",
              "kind",
              "status",
              "duration_ms"
            ],
            "properties": {
              "index": {
                "type": "integer",
                "minimum": 0,
                "maximum": 999
              },
              "kind": {
                "type": "string",
                "enum": [
                  "validate",
                  "plan",
                  "model_call",
                  "tool_call",
                  "repair",
                  "finalize"
                ]
              },
              "provider": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 128
              },
              "model": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 128
              },
              "status": {
                "type": "string",
                "enum": [
                  "success",
                  "failure"
                ]
              },
              "duration_ms": {
                "type": "integer",
                "minimum": 0,
                "maximum": 3600000
              }
            }
          }
        }
      }
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retriable"
      ],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "VALIDATION_ERROR",
            "UNSUPPORTED_SCHEMA",
            "UNAUTHORIZED",
            "REPLAY_DETECTED",
            "TASK_ID_CONFLICT",
            "CAPACITY_EXCEEDED",
            "REMOTE_TIMEOUT",
            "EXECUTION_ERROR",
            "OUTPUT_SCHEMA_MISMATCH",
            "CALLBACK_DELIVERY_FAILED"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "retriable": {
          "type": "boolean"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "key_id",
        "issued_at",
        "expires_at",
        "nonce",
        "signature"
      ],
      "properties": {
        "alg": {
          "const": "Ed25519"
        },
        "key_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]{3,128}$"
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "nonce": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{16,64}$"
        },
        "signature": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{64,512}$"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "success"
          }
        }
      },
      "then": {
        "required": [
          "output"
        ],
        "properties": {
          "error": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failure"
          }
        }
      },
      "then": {
        "required": [
          "error"
        ],
        "properties": {
          "output": {
            "type": "null"
          }
        }
      }
    }
  ]
}

# Runtime mode
ALP_ENV=development
ALP_EXECUTOR_MODE=mock

# Agent keys
AGENT_A_PRIVATE_KEY=CHANGE_ME_AGENT_A_PRIVATE_KEY
AGENT_A_PUBLIC_KEY=CHANGE_ME_AGENT_A_PUBLIC_KEY
AGENT_B_PRIVATE_KEY=CHANGE_ME_AGENT_B_PRIVATE_KEY
AGENT_B_PUBLIC_KEY=CHANGE_ME_AGENT_B_PUBLIC_KEY

# Postgres
POSTGRES_DB=alp
POSTGRES_USER=alp
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
ALP_DATABASE_URL=postgresql://alp:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/alp

# Agent A
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_MODEL_ID=CHANGE_ME_OPENAI_MODEL_ID
CALLBACK_PUBLIC_URL=http://agent-a:8000/callbacks/result

# Agent B
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY
ANTHROPIC_MODEL_ID=CHANGE_ME_ANTHROPIC_MODEL_ID
AGENT_B_PUBLIC_BASE_URL=http://localhost:8080
